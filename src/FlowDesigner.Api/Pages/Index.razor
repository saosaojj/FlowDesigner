@page "/"
@inject FlowApiService ApiService
@inject NavigationManager NavManager

<div class="flows-page">
    <div class="flows-header">
        <div class="header-left">
            <h1><i class="fas fa-project-diagram"></i> 流程管理</h1>
            <p class="subtitle">创建、编辑和管理你的自动化流程</p>
        </div>
        <div class="header-right">
            <button class="btn-primary" @onclick="CreateNewFlow">
                <i class="fas fa-plus"></i> 新建流程
            </button>
        </div>
    </div>

    @if (loading)
    {
        <div class="loading-state">
            <i class="fas fa-spinner fa-spin"></i>
            <span>加载中...</span>
        </div>
    }
    else if (flows == null || flows.Count == 0)
    {
        <div class="empty-state">
            <div class="empty-icon">
                <i class="fas fa-project-diagram"></i>
            </div>
            <h3>还没有流程</h3>
            <p>点击"新建流程"开始创建你的第一个自动化流程</p>
            <button class="btn-primary" @onclick="CreateNewFlow">
                <i class="fas fa-plus"></i> 新建流程
            </button>
        </div>
    }
    else
    {
        <div class="flows-grid">
            @foreach (var flow in flows)
            {
                <div class="flow-card" @onclick="() => OpenFlow(flow.Id)">
                    <div class="card-header">
                        <div class="flow-icon">
                            <i class="fas fa-project-diagram"></i>
                        </div>
                        <div class="flow-status @GetFlowStatusClass(flow)">
                            <i class="fas @GetFlowStatusIcon(flow)"></i>
                            @GetFlowStatusText(flow)
                        </div>
                    </div>
                    <div class="card-body">
                        <h3 class="flow-name">@flow.Name</h3>
                        <p class="flow-desc">@(flow.Description ?? "暂无描述")</p>
                        <div class="flow-stats">
                            <span><i class="fas fa-cube"></i> @flow.Nodes.Count 节点</span>
                            <span><i class="fas fa-link"></i> @flow.Connections.Count 连接</span>
                        </div>
                    </div>
                    <div class="card-footer">
                        <span class="flow-time">
                            <i class="fas fa-clock"></i>
                            @(flow.UpdatedAt?.ToLocalTime().ToString("yyyy-MM-dd HH:mm") ?? "未知")
                        </span>
                        <div class="flow-actions">
                            <button class="btn-icon" @onclick:stopPropagation="true" @onclick="() => OpenFlow(flow.Id)" title="编辑">
                                <i class="fas fa-edit"></i>
                            </button>
                            <button class="btn-icon danger" @onclick:stopPropagation="true" @onclick="() => DeleteFlow(flow.Id)" title="删除">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

@code {
    private bool loading = true;
    private List<Flow>? flows;

    protected override async Task OnInitializedAsync()
    {
        await LoadFlowsAsync();
    }

    private async Task LoadFlowsAsync()
    {
        loading = true;
        try
        {
            flows = await ApiService.GetAllFlowsAsync();
        }
        catch
        {
            flows = new List<Flow>();
        }
        loading = false;
    }

    private void CreateNewFlow()
    {
        var newId = Guid.NewGuid().ToString();
        NavManager.NavigateTo($"/flow/{newId}");
    }

    private void OpenFlow(string flowId)
    {
        NavManager.NavigateTo($"/flow/{flowId}");
    }

    private async Task DeleteFlow(string flowId)
    {
        try
        {
            await ApiService.DeleteFlowAsync(flowId);
            await LoadFlowsAsync();
        }
        catch
        {
        }
    }

    private string GetFlowStatusClass(Flow flow)
    {
        return "status-idle";
    }

    private string GetFlowStatusIcon(Flow flow)
    {
        return "fa-circle";
    }

    private string GetFlowStatusText(Flow flow)
    {
        return "空闲";
    }
}
