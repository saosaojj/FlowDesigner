@page "/flow/{Id}"
@page "/flow/new"
@layout FlowEditorLayout
@inject FlowApiService ApiService
@inject NavigationManager NavManager
@implements IDisposable

<div class="nr-editor">
    <div class="nr-header">
        <div class="nr-header-left">
            <button class="nr-btn nr-btn-icon" @onclick="GoBack" title="返回列表">
                <i class="fas fa-arrow-left"></i>
            </button>
            <div class="nr-flow-tabs">
                <div class="nr-flow-tab active">
                    <i class="fas fa-project-diagram"></i>
                    <input type="text" @bind="flowName" @bind:event="oninput" class="nr-flow-name" />
                </div>
            </div>
        </div>
        <div class="nr-header-right">
            <div class="nr-header-actions">
                <button class="nr-btn nr-btn-icon" @onclick="() => Undo()" disabled="@(undoStack.Count == 0)" title="撤销 (Ctrl+Z)">
                    <i class="fas fa-undo"></i>
                </button>
                <button class="nr-btn nr-btn-icon" @onclick="() => Redo()" disabled="@(redoStack.Count == 0)" title="重做 (Ctrl+Y)">
                    <i class="fas fa-redo"></i>
                </button>
            </div>
            <button class="nr-deploy-btn @(isDeployed ? "deployed" : "")" @onclick="DeployFlow">
                <i class="fas fa-rocket"></i>
                @(isDeployed ? "已部署" : "部署")
            </button>
        </div>
    </div>

    <div class="nr-workspace">
        <div class="nr-sidebar @(sidebarCollapsed ? "collapsed" : "")">
            <div class="nr-sidebar-header">
                @if (!sidebarCollapsed)
                {
                    <div class="nr-sidebar-tabs">
                        <button class="nr-sidebar-tab @(activeTab == "info" ? "active" : "")" @onclick='() => activeTab = "info"'>
                            <i class="fas fa-info-circle"></i> 信息
                        </button>
                        <button class="nr-sidebar-tab @(activeTab == "debug" ? "active" : "")" @onclick='() => activeTab = "debug"'>
                            <i class="fas fa-bug"></i> 调试
                            @if (debugMessages.Count > 0)
                            {
                                <span class="nr-tab-badge">@debugMessages.Count</span>
                            }
                        </button>
                    </div>
                }
                <button class="nr-btn nr-btn-icon nr-collapse-btn" @onclick="ToggleSidebar" title="折叠面板">
                    <i class="fas fa-chevron-left"></i>
                </button>
            </div>
            @if (!sidebarCollapsed)
            {
                <div class="nr-sidebar-content">
                    @if (activeTab == "info")
                    {
                        @if (selectedNodeIds.Count == 1)
                        {
                            var node = CurrentFlow.Nodes.FirstOrDefault(n => n.Id == selectedNodeIds.First());
                            var def = node != null ? GetNodeDefinition(node.Type) : null;
                            <div class="nr-info-panel">
                                <div class="nr-info-header">
                                    <div class="nr-info-icon" style="background-color: @def?.Color">
                                        <i class="fas @def?.Icon"></i>
                                    </div>
                                    <div class="nr-info-title">
                                        <h4>@def?.Name</h4>
                                        <span class="nr-info-type">@node?.Type</span>
                                    </div>
                                </div>
                                <div class="nr-info-desc">@(def?.Description ?? "")</div>
                                <div class="nr-info-props">
                                    <div class="nr-prop-field">
                                        <label>名称</label>
                                        <input type="text" @bind="node!.Label" placeholder="节点名称..." />
                                    </div>
                                    @if (def != null)
                                    {
                                        @foreach (var prop in def.Properties)
                                        {
                                            <div class="nr-prop-field">
                                                <label>@(prop.Value.Label ?? prop.Key)</label>
                                                @switch (prop.Value.Type)
                                                {
                                                    case "string":
                                                        <input type="text"
                                                              value="@node.Properties.GetValueOrDefault(prop.Key)"
                                                              @oninput="(e) => UpdateNodeProperty(node, prop.Key, e.Value?.ToString())" />
                                                        break;
                                                    case "number":
                                                        <input type="number"
                                                              value="@node.Properties.GetValueOrDefault(prop.Key)"
                                                              @oninput="(e) => UpdateNodeProperty(node, prop.Key, e.Value?.ToString())" />
                                                        break;
                                                    case "boolean":
                                                        <label class="nr-toggle">
                                                            <input type="checkbox"
                                                                  checked="@(node.Properties.GetValueOrDefault(prop.Key)?.ToString() == "True")"
                                                                  @onchange="(e) => UpdateNodeProperty(node, prop.Key, e.Value?.ToString())" />
                                                            <span class="nr-toggle-slider"></span>
                                                        </label>
                                                        break;
                                                    case "textarea":
                                                    case "code":
                                                        <textarea rows="6"
                                                                  value="@node.Properties.GetValueOrDefault(prop.Key)"
                                                                  @oninput="(e) => UpdateNodeProperty(node, prop.Key, e.Value?.ToString())"></textarea>
                                                        break;
                                                }
                                            </div>
                                        }
                                    }
                                </div>
                                <button class="nr-btn nr-btn-delete" @onclick="() => DeleteNode(node!)">
                                    <i class="fas fa-trash"></i> 删除节点
                                </button>
                            </div>
                        }
                        else if (selectedNodeIds.Count > 1)
                        {
                            <div class="nr-info-empty">
                                <i class="fas fa-object-group"></i>
                                <p>已选择 @selectedNodeIds.Count 个节点</p>
                                <button class="nr-btn nr-btn-delete" @onclick="DeleteSelectedNodes">
                                    <i class="fas fa-trash"></i> 删除选中
                                </button>
                            </div>
                        }
                        else
                        {
                            <div class="nr-info-empty">
                                <i class="fas fa-mouse-pointer"></i>
                                <p>选择一个节点查看信息</p>
                            </div>
                        }
                    }
                    else if (activeTab == "debug")
                    {
                        <div class="nr-debug-panel">
                            <div class="nr-debug-toolbar">
                                <span><i class="fas fa-bug"></i> 调试输出</span>
                                <button class="nr-btn nr-btn-sm" @onclick="ClearDebugMessages">
                                    <i class="fas fa-trash-alt"></i> 清空
                                </button>
                            </div>
                            <div class="nr-debug-messages">
                                @foreach (var msg in debugMessages)
                                {
                                    <div class="nr-debug-entry nr-debug-@msg.Level">
                                        <span class="nr-debug-time">@msg.Timestamp.ToString("HH:mm:ss")</span>
                                        <span class="nr-debug-source">[@msg.Source]</span>
                                        <pre class="nr-debug-text">@msg.Message</pre>
                                    </div>
                                }
                                @if (debugMessages.Count == 0)
                                {
                                    <div class="nr-info-empty">
                                        <i class="fas fa-inbox"></i>
                                        <p>暂无调试信息</p>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                </div>
            }
        </div>

        <div class="nr-canvas-container">
            <div class="nr-canvas"
                 @ref="canvasContainer"
                 @onwheel="HandleWheel"
                 @onmousedown="CanvasMouseDown"
                 @onmousemove="CanvasMouseMove"
                 @onmouseup="CanvasMouseUp"
                 @onmouseleave="CanvasMouseLeave"
                 @ondragover:preventDefault="true"
                 @ondrop="HandleDrop"
                 @oncontextmenu="ShowContextMenu"
                 @oncontextmenu:preventDefault
                 id="canvasPanel">
                <svg class="nr-svg" xmlns="http://www.w3.org/2000/svg">
                    <defs>
                        <pattern id="nrGridSmall" width="20" height="20" patternUnits="userSpaceOnUse">
                            <circle cx="10" cy="10" r="0.5" fill="rgba(0,0,0,0.1)" />
                        </pattern>
                        <pattern id="nrGridLarge" width="100" height="100" patternUnits="userSpaceOnUse">
                            <rect width="100" height="100" fill="url(#nrGridSmall)" />
                            <circle cx="50" cy="50" r="1" fill="rgba(0,0,0,0.15)" />
                        </pattern>
                        <marker id="nrArrow" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
                            <polygon points="0 0, 8 3, 0 6" fill="#999" />
                        </marker>
                    </defs>
                    <rect width="100%" height="100%" fill="url(#nrGridLarge)" />
                    <g transform="translate(@panX, @panY) scale(@zoom)">
                        @foreach (var connection in CurrentFlow.Connections)
                        {
                            <FlowConnectionLine Connection="connection"
                                               Nodes="CurrentFlow.Nodes"
                                               IsSelected="selectedConnectionId == connection.Id"
                                               OnClick="() => SelectConnection(connection)" />
                        }
                        @if (isCreatingConnection && tempConnection != null)
                        {
                            <path d="@GetTempConnectionPath()"
                                  stroke="#999"
                                  stroke-width="2"
                                  stroke-dasharray="6,3"
                                  fill="none" />
                        }
                        @foreach (var node in CurrentFlow.Nodes)
                        {
                            <FlowNodeCard Node="node"
                                         NodeDefinition="GetNodeDefinition(node.Type)"
                                         IsSelected="selectedNodeIds.Contains(node.Id)"
                                         OnNodeMouseDown="(args) => HandleNodeMouseDown(args.Node, args.Args)"
                                         OnNodeDoubleClick="() => HandleNodeDoubleClick(node)"
                                         OnStartConnection="(port) => StartNodeConnection(node, port)"
                                         OnDelete="() => DeleteNode(node)"
                                         Zoom="zoom" />
                        }
                    </g>
                </svg>

                @if (showContextMenu)
                {
                    <div class="nr-context-menu" style="left: @contextMenuXpx; top: @contextMenuYpx">
                        <button class="nr-menu-item" @onclick="CopySelectedNodes">
                            <i class="fas fa-copy"></i> 复制 <kbd>Ctrl+C</kbd>
                        </button>
                        <button class="nr-menu-item" @onclick="PasteNodes">
                            <i class="fas fa-paste"></i> 粘贴 <kbd>Ctrl+V</kbd>
                        </button>
                        <button class="nr-menu-item" @onclick="DuplicateNodes">
                            <i class="fas fa-clone"></i> 复制并粘贴
                        </button>
                        <div class="nr-menu-divider"></div>
                        <button class="nr-menu-item nr-menu-danger" @onclick="DeleteSelectedNodes">
                            <i class="fas fa-trash"></i> 删除 <kbd>Del</kbd>
                        </button>
                    </div>
                }

                <div class="nr-zoom-controls">
                    <button class="nr-btn nr-btn-zoom" @onclick="ZoomOut" title="缩小">
                        <i class="fas fa-minus"></i>
                    </button>
                    <span class="nr-zoom-level">@((zoom * 100).ToString("F0"))%</span>
                    <button class="nr-btn nr-btn-zoom" @onclick="ZoomIn" title="放大">
                        <i class="fas fa-plus"></i>
                    </button>
                    <button class="nr-btn nr-btn-zoom" @onclick="ZoomReset" title="重置视图">
                        <i class="fas fa-crosshairs"></i>
                    </button>
                </div>

                <div class="nr-canvas-info">
                    <span><i class="fas fa-cube"></i> @CurrentFlow.Nodes.Count</span>
                    <span><i class="fas fa-link"></i> @CurrentFlow.Connections.Count</span>
                </div>
            </div>
        </div>

        <div class="nr-palette @(paletteCollapsed ? "collapsed" : "")">
            <div class="nr-palette-header">
                <button class="nr-btn nr-btn-icon nr-collapse-btn" @onclick="TogglePalette" title="折叠面板">
                    <i class="fas fa-chevron-right"></i>
                </button>
                @if (!paletteCollapsed)
                {
                    <span class="nr-palette-title">节点</span>
                }
            </div>
            @if (!paletteCollapsed)
            {
                <div class="nr-palette-search">
                    <i class="fas fa-search"></i>
                    <input type="text" @bind="searchText" @bind:event="oninput" placeholder="搜索节点..." />
                    @if (!string.IsNullOrWhiteSpace(searchText))
                    {
                        <button class="nr-search-clear" @onclick="ClearSearch">&times;</button>
                    }
                </div>
                <div class="nr-palette-nodes">
                    @foreach (var category in FilteredCategories)
                    {
                        <div class="nr-palette-category">
                            <div class="nr-category-header" @onclick="() => ToggleCategory(category.Key)">
                                <i class="fas @(expandedCategories.Contains(category.Key) ? "fa-chevron-down" : "fa-chevron-right")"></i>
                                <span>@GetCategoryLabel(category.Key)</span>
                                <span class="nr-category-count">@category.Value.Count</span>
                            </div>
                            @if (expandedCategories.Contains(category.Key))
                            {
                                <div class="nr-category-items">
                                    @foreach (var node in category.Value)
                                    {
                                        <div class="nr-palette-node"
                                             draggable="true"
                                             @ondragstart="(e) => StartDragNode(e, node)"
                                             @ondragend="EndDragNode"
                                             title="@node.Description">
                                            <div class="nr-palette-node-color" style="background-color: @node.Color">
                                                <i class="fas @node.Icon"></i>
                                            </div>
                                            <span class="nr-palette-node-label">@node.Name</span>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                    @if (FilteredCategories.Count == 0)
                    {
                        <div class="nr-palette-empty">
                            <i class="fas fa-search"></i>
                            <p>没有找到匹配的节点</p>
                        </div>
                    }
                </div>
            }
        </div>
    </div>

    @if (showEditDialog && editingNode != null)
    {
        var editDef = GetNodeDefinition(editingNode.Type);
        <div class="nr-dialog-overlay" @onclick="CloseEditDialog">
            <div class="nr-dialog" @onclick:stopPropagation="true">
                <div class="nr-dialog-header" style="border-left: 4px solid @editDef?.Color">
                    <div class="nr-dialog-title">
                        <i class="fas @editDef?.Icon" style="color: @editDef?.Color"></i>
                        <span>@(editDef?.Name ?? "编辑节点")</span>
                    </div>
                    <button class="nr-btn nr-btn-icon" @onclick="CloseEditDialog">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <div class="nr-dialog-body">
                    <div class="nr-prop-field">
                        <label>节点名称</label>
                        <input type="text" @bind="editingNode.Label" placeholder="输入节点名称..." />
                    </div>
                    @if (editDef != null)
                    {
                        @foreach (var prop in editDef.Properties)
                        {
                            <div class="nr-prop-field">
                                <label>@(prop.Value.Label ?? prop.Key)</label>
                                @switch (prop.Value.Type)
                                {
                                    case "string":
                                        <input type="text"
                                               value="@editingNode.Properties.GetValueOrDefault(prop.Key)"
                                               @oninput="(e) => UpdateNodeProperty(editingNode, prop.Key, e.Value?.ToString())" />
                                        break;
                                    case "number":
                                        <input type="number"
                                               value="@editingNode.Properties.GetValueOrDefault(prop.Key)"
                                               @oninput="(e) => UpdateNodeProperty(editingNode, prop.Key, e.Value?.ToString())" />
                                        break;
                                    case "boolean":
                                        <label class="nr-toggle">
                                            <input type="checkbox"
                                                   checked="@(editingNode.Properties.GetValueOrDefault(prop.Key)?.ToString() == "True")"
                                                   @onchange="(e) => UpdateNodeProperty(editingNode, prop.Key, e.Value?.ToString())" />
                                            <span class="nr-toggle-slider"></span>
                                        </label>
                                        break;
                                    case "textarea":
                                        <textarea rows="4"
                                                  value="@editingNode.Properties.GetValueOrDefault(prop.Key)"
                                                  @oninput="(e) => UpdateNodeProperty(editingNode, prop.Key, e.Value?.ToString())"></textarea>
                                        break;
                                    case "code":
                                        <textarea rows="10"
                                                  class="nr-code-editor"
                                                  value="@editingNode.Properties.GetValueOrDefault(prop.Key)"
                                                  @oninput="(e) => UpdateNodeProperty(editingNode, prop.Key, e.Value?.ToString())"></textarea>
                                        break;
                                }
                            </div>
                        }
                    }
                </div>
                <div class="nr-dialog-footer">
                    <button class="nr-btn nr-btn-delete" @onclick="() => { DeleteNode(editingNode); CloseEditDialog(); }">
                        <i class="fas fa-trash"></i> 删除
                    </button>
                    <div class="nr-dialog-footer-right">
                        <button class="nr-btn nr-btn-secondary" @onclick="CloseEditDialog">取消</button>
                        <button class="nr-btn nr-btn-primary" @onclick="CloseEditDialog">完成</button>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (showImportDialog)
    {
        <div class="nr-dialog-overlay" @onclick="CloseImportDialog">
            <div class="nr-dialog" @onclick:stopPropagation="true">
                <div class="nr-dialog-header">
                    <div class="nr-dialog-title">
                        <i class="fas @(isExporting ? "fa-file-export" : "fa-file-import")"></i>
                        <span>@(isExporting ? "导出流程" : "导入流程")</span>
                    </div>
                    <button class="nr-btn nr-btn-icon" @onclick="CloseImportDialog">
                        <i class="fas fa-times"></i>
                    </button>
                </div>
                <div class="nr-dialog-body">
                    <textarea @bind="importJson" placeholder="在此粘贴 JSON 数据..." rows="15" class="nr-code-editor"></textarea>
                    @if (!isExporting)
                    {
                        <p class="nr-import-hint">
                            <i class="fas fa-info-circle"></i> 导入将替换当前流程
                        </p>
                    }
                </div>
                <div class="nr-dialog-footer">
                    <button class="nr-btn nr-btn-secondary" @onclick="CloseImportDialog">取消</button>
                    <button class="nr-btn nr-btn-primary" @onclick="HandleImportExport">
                        <i class="fas @(isExporting ? "fa-check" : "fa-file-import")"></i>
                        @(isExporting ? "完成" : "导入")
                    </button>
                </div>
            </div>
        </div>
    }
</div>

@code {
    [Parameter]
    public string Id { get; set; } = string.Empty;

    private Flow CurrentFlow = new();
    private string flowName = "未命名流程";
    private List<NodeDefinition>? nodeDefinitions;
    private Dictionary<string, List<NodeDefinition>> nodeCategories = new();
    private HashSet<string> expandedCategories = new();
    private string searchText = "";
    private HashSet<string> selectedNodeIds = new();
    private string? selectedConnectionId;
    private double panX = 0, panY = 0;
    private double zoom = 1.0;
    private const double ZoomMin = 0.2;
    private const double ZoomMax = 3.0;
    private bool isPanning = false;
    private double lastMouseX, lastMouseY;
    private ElementReference canvasContainer;

    private FlowNode? draggingNode;
    private double nodeDragStartX = 0, nodeDragStartY = 0;
    private double nodeStartX = 0, nodeStartY = 0;
    private bool nodeHasMoved = false;

    private bool isCreatingConnection = false;
    private TempConnectionInfo? tempConnection;
    private string? connectingNodeId;
    private string? connectingPortId;
    private string? _dragNodeType;

    private bool showContextMenu = false;
    private string contextMenuXpx = "0px";
    private string contextMenuYpx = "0px";

    private string activeTab = "info";
    private List<DebugMessage> debugMessages = new();

    private List<Flow> undoStack = new();
    private List<Flow> redoStack = new();

    private List<FlowNode> copiedNodes = new();
    private bool isDeployed = false;
    private bool showImportDialog = false;
    private bool isExporting = false;
    private string importJson = "";

    private bool paletteCollapsed = false;
    private bool sidebarCollapsed = false;

    private bool showEditDialog = false;
    private FlowNode? editingNode;

    private Dictionary<string, List<NodeDefinition>> FilteredCategories
    {
        get
        {
            if (string.IsNullOrWhiteSpace(searchText))
                return nodeCategories;

            return nodeCategories
                .Select(kvp => new KeyValuePair<string, List<NodeDefinition>>(
                    kvp.Key,
                    kvp.Value.Where(n => n.Name.Contains(searchText, StringComparison.OrdinalIgnoreCase) ||
                                        (n.Description ?? "").Contains(searchText, StringComparison.OrdinalIgnoreCase)).ToList()
                ))
                .Where(kvp => kvp.Value.Count > 0)
                .ToDictionary(kvp => kvp.Key, kvp => kvp.Value);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadFlowAsync();
        await LoadNodeDefinitionsAsync();
    }

    private async Task LoadFlowAsync()
    {
        try
        {
            var flow = await ApiService.GetFlowAsync(Id);
            if (flow != null)
            {
                CurrentFlow = flow;
                flowName = flow.Name;
            }
            else
            {
                CurrentFlow = new Flow
                {
                    Id = Id,
                    Name = "新流程",
                    Nodes = new List<FlowNode>(),
                    Connections = new List<Shared.Models.FlowConnection>()
                };
            }
        }
        catch
        {
            CurrentFlow = new Flow
            {
                Id = Id,
                Name = "新流程",
                Nodes = new List<FlowNode>(),
                Connections = new List<Shared.Models.FlowConnection>()
            };
        }
    }

    private async Task LoadNodeDefinitionsAsync()
    {
        try
        {
            nodeDefinitions = await ApiService.GetNodeDefinitionsAsync();
            if (nodeDefinitions != null)
            {
                nodeCategories = nodeDefinitions
                    .GroupBy(n => n.Category)
                    .ToDictionary(g => g.Key, g => g.ToList());
                expandedCategories = new HashSet<string>(nodeCategories.Keys);
            }
        }
        catch
        {
            nodeCategories = new();
        }
    }

    private NodeDefinition? GetNodeDefinition(string? type)
    {
        return nodeDefinitions?.FirstOrDefault(n => n.Type == type);
    }

    private string GetCategoryLabel(string category)
    {
        return category switch
        {
            "input" => "输入",
            "output" => "输出",
            "function" => "功能",
            "network" => "网络",
            "social" => "社交",
            "storage" => "存储",
            "analysis" => "分析",
            "advanced" => "高级",
            "plc" => "PLC 通讯",
            _ => category
        };
    }

    private void ToggleCategory(string category)
    {
        if (expandedCategories.Contains(category))
            expandedCategories.Remove(category);
        else
            expandedCategories.Add(category);
    }

    private void TogglePalette() => paletteCollapsed = !paletteCollapsed;
    private void ToggleSidebar() => sidebarCollapsed = !sidebarCollapsed;
    private void ClearSearch() => searchText = "";

    private void StartDragNode(DragEventArgs e, NodeDefinition nodeDef)
    {
        _dragNodeType = nodeDef.Type;
        e.DataTransfer.EffectAllowed = "copy";
    }

    private void EndDragNode(DragEventArgs e) { }

    private void HandleDrop(DragEventArgs e)
    {
        var nodeType = _dragNodeType;
        if (string.IsNullOrEmpty(nodeType))
            return;

        var nodeDef = GetNodeDefinition(nodeType);
        if (nodeDef == null)
            return;

        var rect = GetCanvasCoordinates(e);
        var node = CreateNodeFromDefinition(nodeDef, rect.X, rect.Y);

        SaveToUndoStack();
        CurrentFlow.Nodes.Add(node);
        selectedNodeIds = new HashSet<string> { node.Id };
        isDeployed = false;
        AddDebugMessage("info", $"已添加节点: {nodeDef.Name}");
        StateHasChanged();
    }

    private CanvasPoint GetCanvasCoordinates(DragEventArgs e)
    {
        var canvasOffsetX = sidebarCollapsed ? 40 : 320;
        var canvasOffsetY = 40;
        return new CanvasPoint
        {
            X = (e.ClientX - canvasOffsetX - panX) / zoom,
            Y = (e.ClientY - canvasOffsetY - panY) / zoom
        };
    }

    private FlowNode CreateNodeFromDefinition(NodeDefinition def, double x, double y)
    {
        var node = new FlowNode
        {
            Id = Guid.NewGuid().ToString(),
            Type = def.Type,
            Label = def.Name,
            X = x - 60,
            Y = y - 15,
            Properties = def.Properties.ToDictionary(
                p => p.Key,
                p => p.Value.DefaultValue
            )
        };

        foreach (var input in def.Inputs)
        {
            node.Inputs.Add(new NodePort
            {
                Id = Guid.NewGuid().ToString(),
                Name = input.Name,
                Type = input.Type
            });
        }

        foreach (var output in def.Outputs)
        {
            node.Outputs.Add(new NodePort
            {
                Id = Guid.NewGuid().ToString(),
                Name = output.Name,
                Type = output.Type
            });
        }

        return node;
    }

    private void HandleWheel(WheelEventArgs e)
    {
        var canvasOffsetX = sidebarCollapsed ? 40 : 320;
        var canvasOffsetY = 40;
        var mouseX = e.ClientX - canvasOffsetX;
        var mouseY = e.ClientY - canvasOffsetY;

        var delta = e.DeltaY > 0 ? -0.1 : 0.1;
        var newZoom = Math.Clamp(zoom + delta, ZoomMin, ZoomMax);

        panX = mouseX - (mouseX - panX) * (newZoom / zoom);
        panY = mouseY - (mouseY - panY) * (newZoom / zoom);

        zoom = newZoom;
        StateHasChanged();
    }

    private void CanvasMouseDown(MouseEventArgs e)
    {
        if (e.Button == 0)
        {
            if (isCreatingConnection)
            {
                EndConnectionCreation();
            }
            else
            {
                isPanning = true;
                lastMouseX = e.ClientX;
                lastMouseY = e.ClientY;
                if (!e.CtrlKey && !e.ShiftKey)
                {
                    selectedNodeIds.Clear();
                    selectedConnectionId = null;
                }
                showContextMenu = false;
            }
        }
    }

    private void CanvasMouseMove(MouseEventArgs e)
    {
        if (draggingNode != null)
        {
            if (!nodeHasMoved)
            {
                SaveToUndoStack();
                nodeHasMoved = true;
            }
            var deltaX = (e.ClientX - nodeDragStartX) / zoom;
            var deltaY = (e.ClientY - nodeDragStartY) / zoom;
            draggingNode.X = nodeStartX + deltaX;
            draggingNode.Y = nodeStartY + deltaY;
            StateHasChanged();
        }
        else if (isPanning)
        {
            panX += e.ClientX - lastMouseX;
            panY += e.ClientY - lastMouseY;
            lastMouseX = e.ClientX;
            lastMouseY = e.ClientY;
            StateHasChanged();
        }
        else if (isCreatingConnection && tempConnection != null)
        {
            var coords = ScreenToCanvas(e.ClientX, e.ClientY);
            tempConnection.EndX = coords.X;
            tempConnection.EndY = coords.Y;
            StateHasChanged();
        }
    }

    private void CanvasMouseUp(MouseEventArgs e)
    {
        if (draggingNode != null)
        {
            draggingNode = null;
            nodeHasMoved = false;
        }
        isPanning = false;
    }

    private void CanvasMouseLeave(MouseEventArgs e)
    {
        if (draggingNode != null)
        {
            draggingNode = null;
            nodeHasMoved = false;
        }
        isPanning = false;
    }

    private CanvasPoint ScreenToCanvas(double screenX, double screenY)
    {
        var canvasOffsetX = sidebarCollapsed ? 40 : 320;
        var canvasOffsetY = 40;
        return new CanvasPoint
        {
            X = (screenX - canvasOffsetX - panX) / zoom,
            Y = (screenY - canvasOffsetY - panY) / zoom
        };
    }

    private void HandleNodeMouseDown(FlowNode node, MouseEventArgs e)
    {
        draggingNode = node;
        nodeDragStartX = e.ClientX;
        nodeDragStartY = e.ClientY;
        nodeStartX = node.X;
        nodeStartY = node.Y;
        nodeHasMoved = false;

        if (e.CtrlKey || e.ShiftKey)
        {
            if (selectedNodeIds.Contains(node.Id))
                selectedNodeIds.Remove(node.Id);
            else
                selectedNodeIds.Add(node.Id);
        }
        else
        {
            if (!selectedNodeIds.Contains(node.Id))
                selectedNodeIds = new HashSet<string> { node.Id };
        }
        showContextMenu = false;
        StateHasChanged();
    }

    private void HandleNodeDoubleClick(FlowNode node)
    {
        editingNode = node;
        showEditDialog = true;
    }

    private void CloseEditDialog()
    {
        showEditDialog = false;
        editingNode = null;
    }

    private void SelectConnection(Shared.Models.FlowConnection connection)
    {
        selectedConnectionId = connection.Id;
        selectedNodeIds.Clear();
        StateHasChanged();
    }

    private void StartNodeConnection(FlowNode node, NodePort port)
    {
        var nodeX = node.X + 120;
        var nodeY = node.Y + 15;

        tempConnection = new TempConnectionInfo
        {
            StartX = nodeX,
            StartY = nodeY,
            EndX = nodeX,
            EndY = nodeY,
            SourceNodeId = node.Id,
            SourcePortId = port.Id
        };

        connectingNodeId = node.Id;
        connectingPortId = port.Id;
        isCreatingConnection = true;
    }

    private void EndConnectionCreation()
    {
        isCreatingConnection = false;
        tempConnection = null;
        connectingNodeId = null;
        connectingPortId = null;
    }

    private string GetTempConnectionPath()
    {
        if (tempConnection == null)
            return "";

        var dx = tempConnection.EndX - tempConnection.StartX;
        var cp = Math.Max(Math.Abs(dx) / 2, 50);

        return $"M {tempConnection.StartX} {tempConnection.StartY} C {tempConnection.StartX + cp} {tempConnection.StartY}, {tempConnection.EndX - cp} {tempConnection.EndY}, {tempConnection.EndX} {tempConnection.EndY}";
    }

    private void UpdateNodeProperty(FlowNode node, string key, string? value)
    {
        node.Properties[key] = value;
        isDeployed = false;
        StateHasChanged();
    }

    private void DeleteNode(FlowNode node)
    {
        SaveToUndoStack();
        CurrentFlow.Nodes.Remove(node);
        CurrentFlow.Connections.RemoveAll(c => c.SourceNodeId == node.Id || c.TargetNodeId == node.Id);
        if (selectedNodeIds.Contains(node.Id))
            selectedNodeIds.Remove(node.Id);
        isDeployed = false;
        AddDebugMessage("warning", $"已删除节点: {node.Label}");
        StateHasChanged();
    }

    private void DeleteSelectedNodes()
    {
        if (selectedNodeIds.Count == 0)
            return;

        SaveToUndoStack();

        var nodesToRemove = CurrentFlow.Nodes.Where(n => selectedNodeIds.Contains(n.Id)).ToList();
        foreach (var node in nodesToRemove)
        {
            CurrentFlow.Nodes.Remove(node);
            CurrentFlow.Connections.RemoveAll(c => c.SourceNodeId == node.Id || c.TargetNodeId == node.Id);
        }

        CurrentFlow.Connections.RemoveAll(c => selectedConnectionId == c.Id);

        selectedNodeIds.Clear();
        selectedConnectionId = null;
        isDeployed = false;
        AddDebugMessage("warning", $"已删除 {nodesToRemove.Count} 个节点");
        StateHasChanged();
        showContextMenu = false;
    }

    private void CopySelectedNodes()
    {
        copiedNodes = CurrentFlow.Nodes.Where(n => selectedNodeIds.Contains(n.Id)).ToList();
        showContextMenu = false;
        AddDebugMessage("info", $"已复制 {copiedNodes.Count} 个节点");
    }

    private void PasteNodes()
    {
        if (copiedNodes.Count == 0)
            return;

        SaveToUndoStack();

        var newNodes = new List<FlowNode>();

        foreach (var node in copiedNodes)
        {
            var newNode = new FlowNode
            {
                Id = Guid.NewGuid().ToString(),
                Type = node.Type,
                Label = node.Label,
                X = node.X + 50,
                Y = node.Y + 50,
                Properties = new Dictionary<string, object?>(node.Properties),
                Inputs = node.Inputs.Select(p => new NodePort
                {
                    Id = Guid.NewGuid().ToString(),
                    Name = p.Name,
                    Type = p.Type
                }).ToList(),
                Outputs = node.Outputs.Select(p => new NodePort
                {
                    Id = Guid.NewGuid().ToString(),
                    Name = p.Name,
                    Type = p.Type
                }).ToList()
            };
            newNodes.Add(newNode);
            CurrentFlow.Nodes.Add(newNode);
        }

        selectedNodeIds = new HashSet<string>(newNodes.Select(n => n.Id));
        showContextMenu = false;
        isDeployed = false;
        AddDebugMessage("info", $"已粘贴 {newNodes.Count} 个节点");
        StateHasChanged();
    }

    private void DuplicateNodes() => PasteNodes();

    private void ShowContextMenu(MouseEventArgs e)
    {
        showContextMenu = true;
        var canvasOffsetX = sidebarCollapsed ? 40 : 320;
        var canvasOffsetY = 40;
        contextMenuXpx = $"{e.ClientX - canvasOffsetX}px";
        contextMenuYpx = $"{e.ClientY - canvasOffsetY}px";
    }

    private void ZoomIn()
    {
        zoom = Math.Min(zoom + 0.1, ZoomMax);
        StateHasChanged();
    }

    private void ZoomOut()
    {
        zoom = Math.Max(zoom - 0.1, ZoomMin);
        StateHasChanged();
    }

    private void ZoomReset()
    {
        zoom = 1.0;
        panX = 0;
        panY = 0;
        StateHasChanged();
    }

    private void SaveToUndoStack()
    {
        undoStack.Add(CloneFlow(CurrentFlow));
        redoStack.Clear();
        if (undoStack.Count > 50)
            undoStack.RemoveAt(0);
    }

    private void Undo()
    {
        if (undoStack.Count == 0)
            return;

        redoStack.Add(CloneFlow(CurrentFlow));
        CurrentFlow = undoStack.Last();
        undoStack.RemoveAt(undoStack.Count - 1);
        AddDebugMessage("info", "撤销操作");
        StateHasChanged();
    }

    private void Redo()
    {
        if (redoStack.Count == 0)
            return;

        undoStack.Add(CloneFlow(CurrentFlow));
        CurrentFlow = redoStack.Last();
        redoStack.RemoveAt(redoStack.Count - 1);
        AddDebugMessage("info", "重做操作");
        StateHasChanged();
    }

    private Flow CloneFlow(Flow flow)
    {
        return new Flow
        {
            Id = flow.Id,
            Name = flow.Name,
            Description = flow.Description,
            Nodes = flow.Nodes.Select(n => new FlowNode
            {
                Id = n.Id,
                Type = n.Type,
                Label = n.Label,
                X = n.X,
                Y = n.Y,
                Properties = new Dictionary<string, object?>(n.Properties),
                Inputs = n.Inputs.Select(p => new NodePort { Id = p.Id, Name = p.Name, Type = p.Type }).ToList(),
                Outputs = n.Outputs.Select(p => new NodePort { Id = p.Id, Name = p.Name, Type = p.Type }).ToList()
            }).ToList(),
            Connections = flow.Connections.Select(c => new Shared.Models.FlowConnection
            {
                Id = c.Id,
                SourceNodeId = c.SourceNodeId,
                SourcePortId = c.SourcePortId,
                TargetNodeId = c.TargetNodeId,
                TargetPortId = c.TargetPortId
            }).ToList(),
            CreatedAt = flow.CreatedAt,
            UpdatedAt = flow.UpdatedAt
        };
    }

    private void DeployFlow()
    {
        SaveToUndoStack();
        isDeployed = true;
        AddDebugMessage("success", "流程已成功部署！");
    }

    private void AddDebugMessage(string level, string message, string source = "系统")
    {
        debugMessages.Insert(0, new DebugMessage
        {
            Level = level,
            Message = message,
            Source = source,
            Timestamp = DateTime.Now
        });

        if (debugMessages.Count > 100)
            debugMessages.RemoveAt(debugMessages.Count - 1);
    }

    private void ClearDebugMessages()
    {
        debugMessages.Clear();
    }

    private void ShowImportDialog()
    {
        isExporting = false;
        showImportDialog = true;
        importJson = "";
    }

    private void CloseImportDialog()
    {
        showImportDialog = false;
    }

    private void HandleImportExport()
    {
        if (isExporting)
            CloseImportDialog();
        else
            ImportFlow();
    }

    private async Task ImportFlow()
    {
        try
        {
            var imported = System.Text.Json.JsonSerializer.Deserialize<Flow>(importJson,
                new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });

            if (imported != null)
            {
                SaveToUndoStack();
                CurrentFlow = imported;
                flowName = imported.Name;
                selectedNodeIds.Clear();
                AddDebugMessage("success", $"成功导入流程: {imported.Name}");
                showImportDialog = false;
            }
        }
        catch (Exception ex)
        {
            AddDebugMessage("error", $"导入失败: {ex.Message}");
        }
    }

    private void ExportFlow()
    {
        var json = System.Text.Json.JsonSerializer.Serialize(CurrentFlow,
            new System.Text.Json.JsonSerializerOptions { WriteIndented = true });
        importJson = json;
        isExporting = true;
        showImportDialog = true;
    }

    private void GoBack()
    {
        NavManager.NavigateTo("/");
    }

    public void Dispose() { }

    private class CanvasPoint
    {
        public double X { get; set; }
        public double Y { get; set; }
    }

    private class TempConnectionInfo
    {
        public double StartX { get; set; }
        public double StartY { get; set; }
        public double EndX { get; set; }
        public double EndY { get; set; }
        public string SourceNodeId { get; set; } = "";
        public string SourcePortId { get; set; } = "";
    }

    private class DebugMessage
    {
        public string Level { get; set; } = "info";
        public string Message { get; set; } = "";
        public string Source { get; set; } = "";
        public DateTime Timestamp { get; set; }
    }
}
