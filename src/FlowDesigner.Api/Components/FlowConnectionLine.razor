@using FlowDesigner.Shared.Models

@if (sourceNode != null && targetNode != null)
{
    var pathData = GetConnectionPath();
    <g class="nr-connection @(IsSelected ? "selected" : "")"
       @onclick="HandleClick"
       style="cursor: pointer;">
        <path d="@pathData"
              stroke="@(IsSelected ? "#ff7700" : "#999")"
              stroke-width="@(IsSelected ? "3" : "2")"
              fill="none" />
        <path d="@pathData"
              stroke="transparent"
              stroke-width="15"
              fill="none"
              style="cursor: pointer;" />
    </g>
}

@code {
    [Parameter]
    public Shared.Models.FlowConnection Connection { get; set; } = null!;

    [Parameter]
    public List<FlowNode> Nodes { get; set; } = null!;

    [Parameter]
    public bool IsSelected { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private FlowNode? sourceNode;
    private FlowNode? targetNode;

    private double StartX => sourceNode != null ? sourceNode.X + 6 + (GetOutputIndex() * 15) + 5 : 0;
    private double StartY => sourceNode != null ? sourceNode.Y + 30 : 0;
    private double EndX => targetNode != null ? targetNode.X + 6 + (GetInputIndex() * 15) + 5 : 0;
    private double EndY => targetNode != null ? targetNode.Y : 0;

    private int GetOutputIndex()
    {
        if (sourceNode == null) return 0;
        var port = sourceNode.Outputs.FirstOrDefault(p => p.Id == Connection.SourcePortId);
        return sourceNode.Outputs.IndexOf(port ?? sourceNode.Outputs.FirstOrDefault()!);
    }

    private int GetInputIndex()
    {
        if (targetNode == null) return 0;
        var port = targetNode.Inputs.FirstOrDefault(p => p.Id == Connection.TargetPortId);
        return targetNode.Inputs.IndexOf(port ?? targetNode.Inputs.FirstOrDefault()!);
    }

    private string GetConnectionPath()
    {
        var dy = EndY - StartY;
        var dx = EndX - StartX;

        if (EndY > StartY)
        {
            var midY = StartY + dy / 2;
            return $"M {StartX} {StartY} C {StartX} {midY}, {EndX} {midY}, {EndX} {EndY}";
        }
        else
        {
            var offset = Math.Max(Math.Abs(dy) / 2, 30);
            return $"M {StartX} {StartY} C {StartX} {StartY + offset}, {EndX} {EndY - offset}, {EndX} {EndY}";
        }
    }

    private void HandleClick(MouseEventArgs e)
    {
        OnClick.InvokeAsync();
    }

    protected override void OnParametersSet()
    {
        sourceNode = Nodes.FirstOrDefault(n => n.Id == Connection.SourceNodeId);
        targetNode = Nodes.FirstOrDefault(n => n.Id == Connection.TargetNodeId);
    }
}
