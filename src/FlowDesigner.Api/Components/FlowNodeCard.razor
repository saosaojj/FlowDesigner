@using FlowDesigner.Shared.Models

<g class="nr-node @(IsSelected ? "selected" : "")"
   transform="translate(@Node.X @Node.Y)"
   @onmousedown:stopPropagation="true"
   @onmousedown="(e) => HandleMouseDown(e)"
   @ondblclick:stopPropagation="true"
   @ondblclick="() => OnNodeDoubleClick.InvokeAsync()">
    <rect class="nr-node-bg"
          x="0" y="0"
          width="120" height="@(GetNodeHeight())"
          rx="5" ry="5"
          fill="@GetNodeBgColor()"
          stroke="@(IsSelected ? "#ff7700" : "#aaa")"
          stroke-width="@(IsSelected ? "2" : "1")" />

    <rect class="nr-node-color-bar"
          x="0" y="0"
          width="6" height="@(GetNodeHeight())"
          rx="5" ry="0"
          fill="@(NodeDefinition?.Color ?? "#999")" />

    @if (Node.Inputs.Count > 0)
    {
        @for (int i = 0; i < Node.Inputs.Count; i++)
        {
            var port = Node.Inputs[i];
            var x = 6 + (i * 15);
            <g class="nr-port nr-port-input"
               @onmousedown:stopPropagation="true"
               @onclick:stopPropagation="true"
               @onclick="() => OnStartConnection.InvokeAsync(port)">
                <rect x="@x" y="-4" width="10" height="8" rx="2" ry="2"
                      fill="@(NodeDefinition?.Color ?? "#999")" stroke="#fff" stroke-width="1" />
            </g>
        }
    }

    @if (Node.Outputs.Count > 0)
    {
        @for (int i = 0; i < Node.Outputs.Count; i++)
        {
            var port = Node.Outputs[i];
            var x = 6 + (i * 15);
            <g class="nr-port nr-port-output"
               @onmousedown:stopPropagation="true"
               @onclick:stopPropagation="true"
               @onclick="() => OnStartConnection.InvokeAsync(port)">
                <rect x="@x" y="@(GetNodeHeight() - 4)" width="10" height="8" rx="2" ry="2"
                      fill="@(NodeDefinition?.Color ?? "#999")" stroke="#fff" stroke-width="1" />
            </g>
        }
    }

    <g class="nr-node-icon" transform="translate(10, 4)">
        <rect x="0" y="0" width="22" height="22" rx="3" ry="3"
              fill="@(NodeDefinition?.Color ?? "#999")" />
        <text x="11" y="16" text-anchor="middle"
              fill="white" font-size="11" font-family="Font Awesome 6 Free" font-weight="900">
            @GetIconUnicode()
        </text>
    </g>

    <text class="nr-node-label"
          x="38" y="18"
          fill="#333" font-size="12" font-weight="500"
          font-family="Helvetica Neue, Arial, sans-serif">
        @GetTruncatedLabel()
    </text>
</g>

@code {
    [Parameter]
    public FlowNode Node { get; set; } = null!;

    [Parameter]
    public NodeDefinition? NodeDefinition { get; set; }

    [Parameter]
    public bool IsSelected { get; set; }

    [Parameter]
    public EventCallback<(FlowNode Node, MouseEventArgs Args)> OnNodeMouseDown { get; set; }

    [Parameter]
    public EventCallback OnNodeDoubleClick { get; set; }

    [Parameter]
    public EventCallback<NodePort> OnStartConnection { get; set; }

    [Parameter]
    public double Zoom { get; set; } = 1.0;

    [Parameter]
    public EventCallback OnDelete { get; set; }

    private double GetNodeHeight()
    {
        return 30;
    }

    private string GetNodeBgColor()
    {
        return IsSelected ? "#fff3e0" : "#fff";
    }

    private string GetTruncatedLabel()
    {
        var label = string.IsNullOrEmpty(Node.Label) ? (NodeDefinition?.Name ?? "Node") : Node.Label;
        return label.Length > 10 ? label.Substring(0, 9) + "…" : label;
    }

    private string GetIconUnicode()
    {
        return NodeDefinition?.Icon switch
        {
            "fa-play" => "\uf04b",
            "fa-bug" => "\uf188",
            "fa-code" => "\uf121",
            "fa-sliders" => "\uf1de",
            "fa-random" => "\uf074",
            "fa-clock" => "\uf017",
            "fa-file-alt" => "\uf15c",
            "fa-globe" => "\uf0ac",
            "fa-reply" => "\uf3e5",
            "fa-cloud-download-alt" => "\uf381",
            "fa-cloud-upload-alt" => "\uf382",
            "fa-download" => "\uf019",
            "fa-upload" => "\uf093",
            "fa-microchip" => "\uf2db",
            "fa-exchange-alt" => "\uf362",
            "fa-stopwatch" => "\uf2f2",
            "fa-sort-numeric-up" => "\uf163",
            "fa-plug" => "\uf1e6",
            "fa-bell" => "\uf0f3",
            "fa-database" => "\uf1c0",
            "fa-plug-circle-bolt" => "\ue55f",
            "fa-plug-circle-check" => "\ue55c",
            "fa-server" => "\uf233",
            "fa-broadcast-tower" => "\uf519",
            "fa-satellite-dish" => "\uf7c0",
            "fa-project-diagram" => "\uf542",
            _ => "\uf1b2"
        };
    }

    private void HandleMouseDown(MouseEventArgs e)
    {
        if (e.Button == 0)
        {
            OnNodeMouseDown.InvokeAsync((Node, e));
        }
    }
}
