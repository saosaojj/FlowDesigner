@using FlowDesigner.Shared.Models

@if (sourceNode != null && targetNode != null)
{
    var pathData = GetConnectionPath();
    <g class="flow-connection @(IsSelected ? "selected" : "")" 
       @onclick="HandleClick"
       @onmouseenter="() => isHovered = true"
       @onmouseleave="() => isHovered = false">
        <path d="@pathData" 
              class="connection-path"
              stroke="@(IsSelected ? "#818cf8" : (isHovered ? "#a5b4fc" : "#6366f1"))" 
              stroke-width="@(IsSelected ? "3" : "2")" 
              fill="none"
              marker-end="url(#arrow)" />
        @if (IsSelected || isHovered)
        {
            <circle cx="@EndX" cy="@EndY" r="5" 
                    fill="@(IsSelected ? "#818cf8" : "#6366f1")" 
                    stroke="white" 
                    stroke-width="2" />
        }
    </g>
}

@code {
    [Parameter]
    public Shared.Models.FlowConnection Connection { get; set; } = null!;

    [Parameter]
    public List<FlowNode> Nodes { get; set; } = null!;

    [Parameter]
    public bool IsSelected { get; set; }

    [Parameter]
    public EventCallback OnClick { get; set; }

    private FlowNode? sourceNode;
    private FlowNode? targetNode;
    private bool isHovered = false;

    private double StartX => sourceNode?.X + 150 ?? 0;
    private double StartY => sourceNode != null ? GetPortY(sourceNode, Connection.SourcePortId, true) : 0;
    private double EndX => targetNode?.X ?? 0;
    private double EndY => targetNode != null ? GetPortY(targetNode, Connection.TargetPortId, false) : 0;

    private double GetPortY(FlowNode node, string portId, bool isOutput)
    {
        var ports = isOutput ? node.Outputs : node.Inputs;
        var index = ports.FindIndex(p => p.Id == portId);
        if (index < 0) index = 0;
        return 35 + (index * 20);
    }

    private string GetConnectionPath()
    {
        var dx = EndX - StartX;
        var dy = EndY - StartY;
        
        var cpOffset = Math.Max(Math.Abs(dx) / 2, 50);
        cpOffset = Math.Min(cpOffset, 150);
        
        var midX = StartX + dx / 2;
        
        if (dx > 0)
        {
            return $"M {StartX} {StartY} C {midX} {StartY}, {midX} {EndY}, {EndX} {EndY}";
        }
        else
        {
            var controlY = Math.Abs(dy) / 2 + 50;
            return $"M {StartX} {StartY} C {StartX + cpOffset} {StartY - controlY}, {EndX - cpOffset} {EndY + controlY}, {EndX} {EndY}";
        }
    }

    private void HandleClick(MouseEventArgs e)
    {
        OnClick.InvokeAsync();
    }

    protected override void OnParametersSet()
    {
        sourceNode = Nodes.FirstOrDefault(n => n.Id == Connection.SourceNodeId);
        targetNode = Nodes.FirstOrDefault(n => n.Id == Connection.TargetNodeId);
    }
}

<style>
    .flow-connection {
        cursor: pointer;
    }
    
    .connection-path {
        transition: stroke 0.2s ease;
    }
    
    .flow-connection:hover .connection-path,
    .flow-connection.selected .connection-path {
        filter: drop-shadow(0 0 4px rgba(99, 102, 241, 0.5));
    }
</style>
